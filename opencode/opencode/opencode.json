{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "lm-studio(MacBook)",
      "options": {
        "baseURL": "http://192.168.68.59:1234/v1"
      },
      "models": {
        "google/gemma-4-31b": {},
        "qwen/qwen3-coder-next": {
          "name": "Qwen-Coder-Next",
          "limit": {
            "context": 262144,
            "output": 65536
          }
        }
      }
    }
  },
  "plugin": [],
  "permission": {
    "bash": {
      "*": "ask",
      "git *": "allow",
      "git commit *": "deny",
      "git push *": "deny",
      "grep *": "allow"
    },
    "edit": "ask",
    "write": "ask"
  }
}
