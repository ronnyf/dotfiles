[submodule "tmux/plugins/tpm"]
	path = tmux/plugins/tpm
	url = https://github.com/tmux-plugins/tpm
    	tag = v3.1.0
[submodule "tmux/plugins/tmux"]
    path = tmux/plugins/tmux
    url = https://github.com/dracula/tmux
    tag = v3.0.0
[submodule "tmux/plugins/tmuxifier"]
    path = tmux/plugins/tmuxifier
    url = https://github.com/jimeh/tmuxifier.git
    branch = main
[submodule "tmux/plugins/vim-tmux-navigator"]
    path = tmux/plugins/vim-tmux-navigator
    url = https://github.com/christoomey/vim-tmux-navigator
    branch = master
[submodule "neovim/nvim"]
	path = neovim/nvim
	url = https://github.com/ronnyf/kickstart.nvim.git
