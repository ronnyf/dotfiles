# If you come from bash you might have to change your $PATH.
export PYENV_ROOT="$HOME/.pyenv"
export PYTHON_PATH=$PYENV_ROOT/shims
export TMUXIFIER_LAYOUT_PATH=$HOME/.config/tmux/layouts
export DOCKER_PATH=$HOME/.docker/bin
export PATH=$HOME/.local/bin:$HOME/.local/share:$PYENV_ROOT/bin:$HOME/.cargo/bin:$PYTHON_PATH:$DOCKER_PATH:/usr/local/bin:$PATH
if [[ "$OSTYPE" == "darwin"* ]]; then
    export HOMEBREW_PATH=/opt/homebrew
    export PATH=$HOMEBREW_PATH/bin:$HOMEBREW_PATH/sbin:$PATH
fi

#node package manager
eval "$(fnm env --use-on-cd --shell zsh)"
export NODE_PATH=$(npm config get prefix)

# Preferred editor for local and remote sessions
export EDITOR='nvim'

# Am I at work?
if [[ -f "$HOME/.iamatwork" ]]; then
    export IAMAT="WORK"
    [[ -f "$HOME/.zshrc.work" ]] && source "$HOME/.zshrc.work"
else
    export IAMAT="HOME"
    [[ -f "$HOME/.zshrc.home" ]] && source "$HOME/.zshrc.home"
fi

# Alias stuff
[[ ! -f "$HOME/.zshrc.alias" ]] || source "$HOME/.zshrc.alias"

# key bindings
bindkey "^[[1;3C" forward-word
bindkey "^[[1;3D" backward-word

EDITOR='nvim'
HISTSIZE=10000
HISTFILE=~/.zsh_history
SAVEHIST=100000
setopt appendhistory
setopt sharehistory
setopt hist_ignore_space
setopt hist_save_no_dups
setopt hist_ignore_all_dups

# Completion Styling
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# fzf
export FZF_DEFAULT_COMMAND='fd --type f'
export FZF_DEFAULT_OPTS="--height 40% --layout=reverse --inline-info --preview 'bat --color=always {}' --preview-window '~3'"

autoload -Uz compinit && compinit -C
zstyle ':completion:*' menu select
zstyle ':completion:*' list-colors "${(s.:.)LS_COLORS}"
zstyle ':completion:*:descriptions' format '[%d]'
zstyle ':completion:*' group-name ''
zstyle ':fzf-tab:*' switch-group '<' '>'

ZSH_AUTOSUGGEST_CLEAR_WIDGETS+=(bracketed-paste up-line-or-search down-line-or-search expand-or-complete accept-line push-line-or-edit)

# Antidote plugin manager — check known install paths (no subprocess fork)
for _ap in /opt/homebrew/opt/antidote /usr/local/opt/antidote /usr/share/zsh-antidote; do
    [[ -f "$_ap/share/antidote/antidote.zsh" ]] && { source "$_ap/share/antidote/antidote.zsh"; break; }
    [[ -f "$_ap/antidote.zsh" ]] && { source "$_ap/antidote.zsh"; break; }
done
antidote load

source <(zoxide init zsh)
[[ -x ~/.tmux/plugins/tmuxifier/bin/tmuxifier ]] && source <(~/.tmux/plugins/tmuxifier/bin/tmuxifier init -)
source <(fzf --zsh)
source <(pyenv init -)
# For sh/bash/zsh/ash/dash/pdksh
source <($HOME/.cargo/env)            
# Secure Credential Storage with macOS Keychain
# eval "$(direnv hook zsh)"

# Set up the Starship prompt
eval "$(starship init zsh)"

# claude specific
[[ ! -f ~/.zshrc.claude ]] || source ~/.zshrc.claude

